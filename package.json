{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "packages/*",
    "artifacts/*",
    "scripts"
  ],
  "scripts": {
    "preinstall": "node scripts/check-pnpm.cjs",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter './artifacts/**' --filter './scripts' --parallel --if-present run typecheck",
    "dev": "pnpm --filter @workspace/api-server run dev",
    "start": "pnpm --filter @workspace/api-server run start",
    "postinstall": "pnpm --filter @workspace/api-server run build"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "@types/express": "^5.0.6"
  },
  "dependencies": {
    "express": "^5.2.1"
  }
}